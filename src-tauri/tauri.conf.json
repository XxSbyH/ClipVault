{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ClipVault",
  "version": "0.1.0",
  "identifier": "com.clipvault.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build:renderer",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClipVault",
        "width": 600,
        "height": 800,
        "minWidth": 520,
        "minHeight": 640,
        "decorations": false
      },
      {
        "label": "hud",
        "title": "ClipVault HUD",
        "url": "hud.html",
        "width": 420,
        "height": 96,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "../resources/icon.ico"
    ]
  }
}
