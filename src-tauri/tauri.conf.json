{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ClipVault",
  "version": "2.1.5",
  "identifier": "com.clipvault.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build:renderer",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClipVault",
        "width": 860,
        "height": 700,
        "minWidth": 760,
        "minHeight": 620,
        "visible": false,
        "decorations": false
      },
      {
        "label": "hud",
        "title": "ClipVault HUD",
        "url": "hud.html",
        "width": 440,
        "height": 64,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "focusable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "search",
        "title": "ClipVault Search",
        "url": "search.html",
        "width": 520,
        "height": 300,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "useLocalToolsDir": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "../resources/icon.ico"
    ]
  }
}
